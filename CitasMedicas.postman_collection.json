{
	"info": {
		"_postman_id": "d119d63d-3081-4292-84ff-2c361f6b1378",
		"name": "CitasMedicas",
		"description": "Microservicio de Reserva de Citas Medicas Veterinarias (Sumativa 3). Desplegado en Render con HATEOAS y Oracle Cloud.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "53623205"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://ms-citas.onrender.com",
			"type": "string",
			"description": "URL publica del microservicio en Render. Cambiar a http://localhost:8081 para pruebas locales."
		}
	],
	"item": [
		{
			"name": "1. Listar todas las citas",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas"]
				},
				"description": "Devuelve la coleccion completa con _embedded.citaMedicaList y bloque _links HATEOAS."
			},
			"response": []
		},
		{
			"name": "2. Consultar cita por ID",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas/1",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas", "1"]
				},
				"description": "Devuelve una cita con sus 5 enlaces HATEOAS (self, citas, disponibilidad, cancelar, eliminar)."
			},
			"response": []
		},
		{
			"name": "3. Consultar cita inexistente (404)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas/9999",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas", "9999"]
				},
				"description": "Caso de error: ID que no existe. Espera 404 con mensaje en JSON."
			},
			"response": []
		},
		{
			"name": "4. Disponibilidad por fecha (todos los veterinarios)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas/disponibilidad?fecha=2026-05-15",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas", "disponibilidad"],
					"query": [
						{ "key": "fecha", "value": "2026-05-15" }
					]
				},
				"description": "Lista los horarios libres y ocupados para una fecha sin filtrar por veterinario."
			},
			"response": []
		},
		{
			"name": "5. Disponibilidad por fecha + veterinario",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas/disponibilidad?fecha=2026-05-15&veterinario=Dr. Rodríguez",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas", "disponibilidad"],
					"query": [
						{ "key": "fecha", "value": "2026-05-15" },
						{ "key": "veterinario", "value": "Dr. Rodríguez" }
					]
				},
				"description": "Disponibilidad filtrada por veterinario. Util para programar sin solapar."
			},
			"response": []
		},
		{
			"name": "6. Programar cita",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"paciente\": \"Maria Ovalle\",\n  \"mascota\": \"Mochi\",\n  \"tipoMascota\": \"Gato\",\n  \"veterinario\": \"Dra. Martínez\",\n  \"fecha\": \"2026-05-20\",\n  \"hora\": \"11:00\",\n  \"motivo\": \"Control anual y desparasitacion\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/api/citas",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas"]
				},
				"description": "Programa una cita nueva. Espera 201 con la cita persistida y sus _links."
			},
			"response": []
		},
		{
			"name": "7. Programar cita invalida (validaciones)",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"paciente\": \"\",\n  \"mascota\": \"\",\n  \"veterinario\": \"\",\n  \"fecha\": \"2020-01-01\",\n  \"hora\": \"99:99\",\n  \"motivo\": \"\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/api/citas",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas"]
				},
				"description": "Caso de error: campos vacios, fecha pasada y hora invalida. Espera 400 con lista completa de errores."
			},
			"response": []
		},
		{
			"name": "8. Programar cita en horario ocupado",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"paciente\": \"Otro Cliente\",\n  \"mascota\": \"Otro\",\n  \"tipoMascota\": \"Perro\",\n  \"veterinario\": \"Dra. Martínez\",\n  \"fecha\": \"2026-05-20\",\n  \"hora\": \"11:00\",\n  \"motivo\": \"Conflicto con cita existente\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/api/citas",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas"]
				},
				"description": "Caso de error: intenta agendar el mismo horario y veterinario que la peticion 6. Espera 400 con mensaje de horario ocupado."
			},
			"response": []
		},
		{
			"name": "9. Cancelar cita",
			"request": {
				"method": "PUT",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas/2/cancelar",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas", "2", "cancelar"]
				},
				"description": "Cancela la cita 2. No se puede cancelar una cita ya cancelada o completada (devuelve 400)."
			},
			"response": []
		},
		{
			"name": "10. Eliminar cita",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/citas/5",
					"host": ["{{baseUrl}}"],
					"path": ["api", "citas", "5"]
				},
				"description": "Elimina la cita 5. Si ya fue eliminada antes devuelve 404. Cambiar el ID si hace falta."
			},
			"response": []
		}
	]
}
