# Maven build output (no versionamos artefactos generados;
# los Dockerfiles usan multi-stage build y compilan el JAR dentro
# del contenedor a partir del codigo fuente)
**/target/
*.class
*.jar
*.war

# IDE files
.idea/
*.iml
.vscode/
*.suo
*.user

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Documentos que no son código (rubricas, guias, instrucciones)
*.docx
*.pdf
*.zip
*.rar
